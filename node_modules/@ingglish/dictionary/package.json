{
  "name": "@ingglish/dictionary",
  "version": "0.1.1",
  "description": "CMU dictionary loading, lookup, and word frequency scoring for Ingglish",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "prebuild": "npm run update-dictionaries",
    "pretest": "npm run update-dictionaries",
    "build": "tsup",
    "build:fast": "npm run update-dictionaries && tsup src/index.ts --format esm",
    "lint": "eslint --cache src",
    "test": "vitest run --no-color",
    "update-dictionaries": "node scripts/ensure-dictionaries.cjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ingglish/phonemes": "^0.1.0",
    "subtlex-word-frequencies": "^2.0.0"
  },
  "author": "Paul Tarjan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ptarjan/ingglish.git",
    "directory": "packages/dictionary"
  },
  "homepage": "https://github.com/ptarjan/ingglish#readme",
  "bugs": {
    "url": "https://github.com/ptarjan/ingglish/issues"
  }
}
