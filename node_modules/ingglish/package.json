{
  "name": "ingglish",
  "version": "0.1.1",
  "description": "Core phonetic English translation library",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "tsup",
    "build:fast": "tsup src/index.ts --format esm",
    "lint": "eslint --cache src",
    "test": "vitest run --no-color",
    "bench": "vitest bench --no-color",
    "test:watch": "vitest",
    "translate": "npx vite-node scripts/cli/translate.ts",
    "debug:roundtrip": "npx vite-node scripts/cli/debug-roundtrip.ts",
    "analyze-collisions": "npx vite-node scripts/cli/collision-analysis.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ingglish/normalize": "^0.1.0",
    "@ingglish/phonemes": "^0.1.0",
    "@ingglish/ipa": "^0.1.0",
    "@ingglish/dictionary": "^0.1.0",
    "@ingglish/fallback": "^0.1.0",
    "@ingglish/g2p": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "jsdom": "^28.1.0",
    "vite": "^7.3.1"
  },
  "keywords": [
    "phonetic",
    "english",
    "pronunciation",
    "spelling",
    "ipa",
    "cmu",
    "dictionary"
  ],
  "author": "Paul Tarjan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ptarjan/ingglish.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/ptarjan/ingglish#readme",
  "bugs": {
    "url": "https://github.com/ptarjan/ingglish/issues"
  }
}
